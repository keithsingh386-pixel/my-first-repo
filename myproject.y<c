<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Higher Place Logo</title>
    <!-- Import Old English Style Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=UnifrakturMaguntia&display=swap" rel="stylesheet">
    
    <style>
        /* Dark Mode UI Base */
        body {
            background-color: #121212; /* Deep Dark Background */
            color: #ffffff;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* Logo Container */
        .logo-container {
            text-align: center;
            padding: 40px;
            border: 2px solid #333;
            border-radius: 15px;
            background: linear-gradient(145deg, #1e1e1e, #121212);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }

        /* Logo Text Styling */
        .logo-text {
            font-family: 'UnifrakturMaguntia', cursive; /* Old English Style */
            font-size: 4rem;
            color: #d4af37; /* Metallic Gold */
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.8);
            margin: 0;
            letter-spacing: 2px;
            line-height: 1.2;
        }

        /* Subtitle or Tagline (Optional) */
        .logo-tagline {
            font-family: 'Segoe UI', sans-serif;
            font-size: 1rem;
            color: #888;
            margin-top: 10px;
            text-transform: uppercase;
            letter-spacing: 4px;
        }

        /* Responsive Adjustments */
        @media (max-width: 600px) {
            .logo-text {
                font-size: 2.5rem;
            }
        }
    </style>
</head>
<body>

    <div class="logo-container">
        <h1 class="logo-text">Higher Place</h1>
        <div class="logo-tagline">Elevate Your Vision</div>
    </div>

</body>
</html>

